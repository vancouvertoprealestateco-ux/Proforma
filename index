// PDF Extraction via Claude API
async function handleFileUpload(event){
  const file=event.target.files[0];
  if(!file)return;
  const status=document.getElementById('upload-status');
  const zone=document.getElementById('upload-zone');
  status.style.display='block';

  // Bug 5: Check if running locally (file:// protocol) — Claude API blocks this
  if(window.location.protocol === 'file:'){
    status.className='upload-status error';
    status.innerHTML='⚠ <strong>File extraction unavailable in local mode.</strong><br>Ap-Ex must be hosted on a web server (e.g. GitHub Pages, Netlify) for the AI extraction feature to work. Please enter details manually for now.';
    event.target.value='';
    return;
  }

  status.className='upload-status loading';
  status.textContent='🔍 Reading document — extracting building data...';
  zone.style.borderColor='var(--gold)';

  try{
    // Read file as base64
    const base64=await new Promise((res,rej)=>{
      const reader=new FileReader();
      reader.onload=()=>res(reader.result.split(',')[1]);
      reader.onerror=()=>rej(new Error('File read failed'));
      reader.readAsDataURL(file);
    });
    const isPdf=file.type==='application/pdf';
    const mediaType=isPdf?'application/pdf':file.type;

    const prompt=`You are analyzing an architectural plan or real estate proforma document.
Extract the following data points if present. Respond ONLY with a valid JSON object — no markdown, no explanation.
Keys to extract (use null if not found):
{
  "project_name": string,
  "project_type": string,
  "address": string,
  "city": string,
  "legal": string,
  "architect": string,
  "zoning": string,
  "gba_A": number (Gross Buildable Area Building A, in SF),
  "gba_B": number, "gba_C": number, "gba_D": number,
  "rentable_A": number (Net Saleable / Rentable Area Building A, in SF),
  "rentable_B": number, "rentable_C": number, "rentable_D": number,
  "units_A": number (units Building A), "units_B": number, "units_C": number, "units_D": number,
  "parking_A": number (parking stalls Building A), "parking_B": number, "parking_C": number, "parking_D": number,
  "bicycles_A": number (bicycle stalls), "bicycles_B": number, "bicycles_C": number, "bicycles_D": number,
  "storage_A": number (storage lockers), "storage_B": number, "storage_C": number, "storage_D": number,
  "sale_psf_quick": number (sale price per SF if given),
  "rent_psf": number (monthly rent per leasable SF if given),
  "cap_rate": number (cap rate as decimal, e.g. 0.0475),
  "park_price": number (parking sale $/stall),
  "bike_price": number (bicycle sale $/stall),
  "storage_price": number (storage sale $/unit),
  "dcc": number, "cac": number,
  "constr_psf": number (construction cost per SF)
}
If document mentions only one building, only fill the _A keys and set others to null.`;

    const body={
      model:'claude-sonnet-4-20250514',
      max_tokens:1000,
      messages:[{
        role:'user',
        content:[
          {type:isPdf?'document':'image',
           source:{type:'base64',media_type:mediaType,data:base64}},
          {type:'text',text:prompt}
        ]
      }]
    };

    const resp=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify(body)
    });
    const data=await resp.json();
    const text=(data.content||[]).filter(b=>b.type==='text').map(b=>b.text).join('');
    const clean=text.replace(/```json|```/g,'').trim();
    const extracted=JSON.parse(clean);

    // Use setBuildingValues so dynamic buildings show up based on extracted data
    setBuildingValues(extracted);
    let filled = 0;
    Object.entries(extracted).forEach(([k,v]) => {
      if(v === null || v === undefined) return;
      // Skip building-specific keys (already handled by setBuildingValues)
      if(/^(gba|rentable|units|parking|bicycles|storage)_[A-H]$/.test(k)) { filled++; return; }
      const el = document.querySelector('[data-key="' + k + '"]');
      if(el) { el.value = v; filled++; }
      // Sync sale_psf to A/B/C/D etc.
      if(k === 'sale_psf_quick'){
        ['A','B','C','D','E','F'].forEach(letter => {
          const b = document.querySelector('[data-key="sale_psf_' + letter + '"]');
          if(b) b.value = v;
        });
      }
    });

    updateOutput();
    updateTotals();
    checkReady();
    status.className='upload-status done';
    status.textContent='✓ Extracted '+filled+' fields from document. Review and adjust as needed.';
    zone.style.borderColor='';
    // Switch to Project tab to show results
    switchTab(0,document.querySelectorAll('.tab')[0]);

  }catch(err){
    console.error(err);
    status.className='upload-status error';
    status.innerHTML='⚠ <strong>Could not extract data.</strong><br>The document may be unreadable or the AI service is unavailable. Please enter details manually.';
    zone.style.borderColor='';
  }
  // Reset file input so same file can be re-uploaded
  event.target.value='';
}

// Drag and drop on upload zone
const zone=document.getElementById('upload-zone');
if(zone){
  zone.addEventListener('dragover',e=>{e.preventDefault();zone.classList.add('drag-over');});
  zone.addEventListener('dragleave',()=>zone.classList.remove('drag-over'));
  zone.addEventListener('drop',e=>{
    e.preventDefault();
    zone.classList.remove('drag-over');
    const file=e.dataTransfer.files[0];
    if(file){
      document.getElementById('file-input').files=e.dataTransfer.files;
      handleFileUpload({target:{files:e.dataTransfer.files,value:''}});
    }
  });
}

