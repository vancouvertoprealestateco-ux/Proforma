<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ap-Ex — Pro Forma Tool by TOP REAL ESTATE . AI</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --gold:#C9A84C;--gold-dim:rgba(201,168,76,0.12);--gold-mid:rgba(201,168,76,0.25);
  --navy:#0A1628;--dark:#060e1c;--panel:#0d1b2e;--card:#111f35;--border:#1b2e48;
  --muted:#6b88aa;--text:#dde8f4;--text-dim:#8faac4;
  --green:#0d9e6e;--red:#c94c4c;--green-dim:rgba(13,158,110,.12);--red-dim:rgba(201,76,76,.12);
  --serif:'Cormorant Garamond',Georgia,serif;
  --sans:'DM Sans',system-ui,sans-serif;
  --mono:'DM Mono',monospace;
  --r:6px;--r-lg:10px;
}
html,body{height:100%;background:var(--dark);color:var(--text);font-family:var(--sans);font-size:13px;overflow:hidden}

/* ── LAYOUT ── */
.app{display:grid;grid-template-rows:52px 1fr;height:100vh}
.main{display:grid;grid-template-columns:210px 1fr 260px;overflow:hidden}

/* ── TOPBAR ── */
.topbar{background:var(--navy);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 18px;gap:14px;z-index:100}
.logo{font-family:var(--serif);font-size:20px;font-weight:700;color:var(--gold);letter-spacing:.5px;white-space:nowrap}
.logo-sub{font-family:var(--sans);font-size:10px;color:var(--muted);font-weight:400;letter-spacing:1.5px;text-transform:uppercase;margin-left:6px;border-left:1px solid var(--border);padding-left:10px}
.proj-name-input{flex:1;max-width:260px;background:transparent;border:none;border-bottom:1px solid var(--border);color:var(--text);font-family:var(--sans);font-size:13px;font-weight:500;padding:3px 0;outline:none;transition:.2s}
.proj-name-input:focus{border-color:var(--gold)}
.topbar-right{margin-left:auto;display:flex;gap:7px;align-items:center}
.save-dot{width:6px;height:6px;border-radius:50%;background:var(--gold);animation:blink 1s infinite;display:none}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
.btn{font-family:var(--sans);font-size:12px;font-weight:500;padding:5px 14px;border-radius:var(--r);border:1px solid var(--border);background:transparent;color:var(--text-dim);cursor:pointer;transition:.15s;white-space:nowrap}
.btn:hover{background:var(--card);color:var(--text);border-color:var(--muted)}
.btn-gold{background:var(--gold);color:#06101c;border-color:var(--gold);font-weight:600}
.btn-gold:hover{background:#d4ad40;border-color:#d4ad40}
.btn-danger{color:#e07070;border-color:#3d1515}
.btn-danger:hover{background:#3d1515;color:#f09090}

/* ── SIDEBAR ── */
.sidebar{background:#07111e;border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden}
.sidebar-hdr{padding:14px 14px 10px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border)}
.sidebar-title{font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:1.2px}
.btn-new{font-size:11px;padding:3px 10px;border-radius:4px;border:1px solid var(--border);background:transparent;color:var(--gold);cursor:pointer;font-family:var(--sans);transition:.15s}
.btn-new:hover{background:var(--gold-dim);border-color:var(--gold)}
.proj-list{flex:1;overflow-y:auto;padding:8px}
.proj-list::-webkit-scrollbar{width:3px}
.proj-list::-webkit-scrollbar-track{background:transparent}
.proj-list::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
.proj-item{padding:10px 11px;border-radius:var(--r);cursor:pointer;margin-bottom:3px;border:1px solid transparent;transition:.15s}
.proj-item:hover{background:var(--panel);border-color:var(--border)}
.proj-item.active{background:var(--gold-dim);border-color:rgba(201,168,76,.3)}
.proj-item-name{font-size:12px;font-weight:500;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.proj-item-meta{font-size:10px;color:var(--muted);margin-top:2px}
.proj-empty{padding:30px 14px;text-align:center;color:var(--muted);font-size:11px;line-height:1.8}
.proj-empty .icon{font-size:28px;margin-bottom:8px;opacity:.4}

/* ── MAIN CONTENT ── */
.content{display:flex;flex-direction:column;overflow:hidden}
.tabs-bar{display:flex;border-bottom:1px solid var(--border);background:#08121f;padding:0 18px;flex-shrink:0}
.tab{font-family:var(--sans);font-size:12px;font-weight:500;color:var(--muted);padding:12px 15px;cursor:pointer;border-bottom:2px solid transparent;transition:.15s;white-space:nowrap}
.tab:hover:not(.active){color:var(--text)}
.tab.active{color:var(--gold);border-bottom-color:var(--gold)}
.tab-content{flex:1;overflow-y:auto;padding:18px 20px}
.tab-content::-webkit-scrollbar{width:4px}
.tab-content::-webkit-scrollbar-track{background:transparent}
.tab-content::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px}

/* ── FORM ELEMENTS ── */
.section-hdr{font-size:10px;font-weight:600;color:var(--gold);text-transform:uppercase;letter-spacing:1.2px;padding-bottom:6px;border-bottom:1px solid var(--border);margin:20px 0 10px}
.section-hdr:first-child{margin-top:0}
.field{display:grid;grid-template-columns:minmax(170px,240px) minmax(200px,1fr);gap:14px;align-items:center;margin-bottom:7px}
.field label{font-size:11px;color:var(--muted);line-height:1.4}
.field input,.field .inp-wrap{width:100%;max-width:420px}
.field .inp-wrap input{max-width:none}
.field.required-missing label{color:var(--red)}
.field.required-missing input{border-color:var(--red)!important;background:rgba(201,76,76,.07)!important;cursor:pointer}
.field.required-missing input::placeholder{color:var(--red);opacity:.6}
.field.calc-field input{background:rgba(201,168,76,.05)!important;color:var(--gold)!important;cursor:not-allowed}
/* Building card */
.bldg-card{background:var(--panel);border:1px solid var(--border);border-radius:var(--r-lg);padding:14px 16px;margin-bottom:12px;transition:.2s}
.bldg-card-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid var(--border)}
.bldg-card-title{font-size:12px;font-weight:600;color:var(--gold);background:var(--gold-dim);padding:4px 10px;border-radius:4px}
.bldg-remove{background:transparent;border:1px solid transparent;color:var(--muted);width:24px;height:24px;border-radius:4px;cursor:pointer;font-size:14px;line-height:1;transition:.15s}
.bldg-remove:hover{border-color:var(--red);color:var(--red);background:var(--red-dim)}
.bldg-grid{display:grid;grid-template-columns:1fr 1fr;gap:0 28px}
.add-bldg-btn{display:block;width:100%;padding:10px;border:1.5px dashed var(--border);border-radius:var(--r-lg);background:transparent;color:var(--muted);font-size:12px;font-weight:500;cursor:pointer;transition:.15s;margin:6px 0 12px;font-family:var(--sans)}
.add-bldg-btn:hover{border-color:var(--gold);color:var(--gold);background:var(--gold-dim)}
.add-bldg-btn:disabled{opacity:.3;cursor:not-allowed}
/* Totals row */
.totals-card{background:var(--navy);border:1px solid rgba(201,168,76,.3);border-radius:var(--r-lg);padding:12px 16px;margin-top:8px}
.totals-hdr{font-size:11px;font-weight:700;color:var(--gold);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;text-align:center}
.totals-row{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.totals-cell{text-align:center;padding:5px}
.totals-lbl{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px}
.totals-val{font-size:14px;font-weight:600;font-family:var(--mono);color:var(--text)}
.totals-val.gold{color:var(--gold)}
/* Unit toggle */
.unit-toggle{display:inline-flex;gap:0;border:1px solid var(--border);border-radius:var(--r);overflow:hidden;margin-left:10px;vertical-align:middle}
.unit-btn{font-size:10px;font-weight:600;padding:3px 9px;background:transparent;color:var(--muted);border:none;cursor:pointer;font-family:var(--sans);transition:.15s;letter-spacing:.3px}
.unit-btn:not(:last-child){border-right:1px solid var(--border)}
.unit-btn.active{background:var(--gold);color:#06101c}
.unit-btn:hover:not(.active){background:var(--card);color:var(--text)}
/* Upload sidebar */
.upload-zone{margin:10px 8px;border:1.5px dashed var(--border);border-radius:var(--r-lg);padding:16px 10px;text-align:center;cursor:pointer;transition:.2s;position:relative}
.upload-zone:hover,.upload-zone.drag-over{border-color:var(--gold);background:var(--gold-dim)}
.upload-zone input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.upload-icon{font-size:22px;margin-bottom:6px;opacity:.6}
.upload-label{font-size:11px;color:var(--muted);line-height:1.5}
.upload-label strong{color:var(--gold);display:block;margin-bottom:2px}
.upload-status{margin:6px 8px;padding:7px 10px;border-radius:var(--r);font-size:11px;display:none}
.upload-status.loading{background:var(--gold-dim);border:1px solid rgba(201,168,76,.3);color:var(--gold)}
.upload-status.done{background:var(--green-dim);border:1px solid rgba(13,158,110,.25);color:#4dd9a0}
.upload-status.error{background:var(--red-dim);border:1px solid rgba(201,76,76,.2);color:#e08080}
/* Ready badge */
.ready-banner{margin:12px 0 0;padding:10px 14px;background:var(--green-dim);border:1px solid rgba(13,158,110,.3);border-radius:var(--r);display:none}
.ready-banner .ready-title{font-size:13px;font-weight:600;color:#4dd9a0;margin-bottom:4px}
.ready-banner .ready-sub{font-size:11px;color:var(--muted);margin-bottom:8px}
.ready-actions{display:flex;gap:6px}
.share-link-box{margin-top:8px;display:none}
.share-link-box input{width:100%;background:var(--panel);border:1px solid var(--border);color:var(--text);padding:5px 8px;border-radius:var(--r);font-size:11px;font-family:var(--mono)}
.share-btns{display:flex;gap:5px;margin-top:5px}
.share-btn{flex:1;font-size:11px;padding:4px 8px;border-radius:4px;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;font-family:var(--sans);transition:.15s;text-align:center}
.share-btn:hover{border-color:var(--gold);color:var(--gold);background:var(--gold-dim)}
/* Proj list stays below upload */
.proj-divider{padding:8px 14px 4px;font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:1px;border-top:1px solid var(--border);margin-top:4px;display:flex;align-items:center;justify-content:space-between}
/* Modal */
.modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:200;display:none;align-items:center;justify-content:center;backdrop-filter:blur(2px)}
.modal-backdrop.show{display:flex}
.modal{background:var(--panel);border:1px solid var(--border);border-radius:var(--r-lg);max-width:460px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,.5)}
.modal-hdr{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.modal-title{font-family:var(--serif);font-size:18px;font-weight:600;color:var(--gold)}
.modal-close{background:transparent;border:none;color:var(--muted);font-size:22px;cursor:pointer;padding:0;line-height:1;width:24px;height:24px;border-radius:4px;transition:.15s}
.modal-close:hover{background:var(--card);color:var(--text)}
.modal-body{padding:14px 18px 18px}
.export-option{display:flex;gap:14px;align-items:center;padding:12px 14px;border:1px solid var(--border);border-radius:var(--r);cursor:pointer;margin-bottom:8px;transition:.15s;background:var(--card)}
.export-option:hover{border-color:var(--gold);background:var(--gold-dim)}
.export-icon{font-size:24px;opacity:.7}
.export-title{font-size:13px;font-weight:600;color:var(--text);margin-bottom:2px}
.export-sub{font-size:11px;color:var(--muted)}
.export-note{margin-top:12px;padding:10px 12px;background:var(--card);border-radius:var(--r);border:1px solid var(--border);font-size:11px;color:var(--muted);line-height:1.6}
.export-note code{background:var(--navy);color:var(--gold);padding:1px 5px;border-radius:3px;font-family:var(--mono);font-size:10px}
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:var(--green-dim);border:1px solid rgba(13,158,110,.4);color:#4dd9a0;padding:10px 18px;border-radius:var(--r);font-size:12px;font-weight:500;z-index:300;display:none;animation:slideUp .3s}
.toast.error{background:var(--red-dim);border-color:rgba(201,76,76,.4);color:#e08080}
@keyframes slideUp{from{transform:translate(-50%,20px);opacity:0}to{transform:translateX(-50%);opacity:1}}
.inp-wrap{position:relative;display:flex;align-items:center}
.inp-pre,.inp-suf{position:absolute;font-size:11px;color:var(--muted);pointer-events:none;font-family:var(--mono)}
.inp-pre{left:8px}
.inp-suf{right:8px}
input[type="number"],input[type="text"]{width:100%;background:var(--panel);border:1px solid var(--border);color:var(--text);padding:5px 9px;border-radius:var(--r);font-size:12px;font-family:var(--mono);outline:none;transition:.15s;-moz-appearance:textfield}
input[type="number"]::-webkit-inner-spin-button{-webkit-appearance:none}
input[type="number"]:focus,input[type="text"]:focus{border-color:var(--gold);background:var(--card)}
input.has-pre{padding-left:18px}
input.has-suf{padding-right:24px}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.bldg-label{font-size:11px;font-weight:600;color:var(--gold);margin-bottom:8px;padding:3px 8px;background:var(--gold-dim);border-radius:4px;display:inline-block}
.preset-row{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:14px}
.preset-btn{font-size:11px;padding:4px 11px;border-radius:4px;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;font-family:var(--sans);transition:.15s}
.preset-btn:hover{border-color:var(--gold);color:var(--gold);background:var(--gold-dim)}
.preset-btn.active{border-color:var(--gold);color:var(--gold);background:var(--gold-dim);font-weight:600}
.note{font-size:10px;color:var(--muted);opacity:.6;margin-top:2px}
.sep{height:1px;background:var(--border);margin:16px 0}

/* ── OUTPUT PANEL ── */
.out-panel{background:#07111e;border-left:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden}
.out-hdr{padding:12px 15px 10px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.out-hdr-title{font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:1.2px}
.out-body{flex:1;overflow-y:auto;padding:12px 14px}
.out-body::-webkit-scrollbar{width:3px}
.out-body::-webkit-scrollbar-thumb{background:var(--border)}
.feasible{margin-bottom:10px;padding:7px 10px;border-radius:var(--r);font-size:11px;font-weight:600;text-align:center;letter-spacing:.3px}
.feasible.ok{background:var(--green-dim);border:1px solid rgba(13,158,110,.25);color:#4dd9a0}
.feasible.warn{background:var(--red-dim);border:1px solid rgba(201,76,76,.2);color:#e08080}
.dual-hdrs{display:grid;grid-template-columns:1fr 1fr;gap:5px;margin-bottom:7px}
.dual-hdr{text-align:center;font-size:10px;font-weight:700;padding:5px;background:var(--gold-dim);border:1px solid rgba(201,168,76,.2);border-radius:4px;color:var(--gold);letter-spacing:.5px}
.out-row{display:grid;grid-template-columns:1fr 1fr;gap:5px;margin-bottom:4px}
.out-cell{padding:5px 7px;border-radius:4px;background:var(--panel);border:1px solid var(--border)}
.out-cell.blank{background:transparent;border-color:transparent}
.out-lbl{font-size:9px;color:var(--muted);letter-spacing:.3px;margin-bottom:2px}
.out-val{font-size:12px;font-weight:500;color:var(--text);font-family:var(--mono)}
.out-val.gold{color:var(--gold)}
.out-val.neg{color:var(--red)}
.out-val.green{color:var(--green)}
.divider{height:1px;background:var(--border);margin:8px 0}
.bps-section{background:var(--navy);border:1px solid var(--border);border-radius:var(--r);padding:10px;margin:8px 0}
.bps-title{font-size:9px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px}
.bps-tiles{display:grid;grid-template-columns:1fr 1fr 1fr;gap:5px}
.bps-tile{text-align:center;background:var(--card);border:1px solid var(--border);border-radius:4px;padding:7px 4px}
.bps-t{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.6px;margin-bottom:3px}
.bps-v{font-size:17px;font-weight:700;font-family:var(--serif);color:var(--gold)}
.kpi-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:5px;margin-top:8px}
.kpi{text-align:center;background:var(--card);border:1px solid var(--border);border-radius:4px;padding:7px 4px}
.kpi-t{font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:3px}
.kpi-v{font-size:15px;font-weight:600;font-family:var(--sans);color:var(--text)}
.exit-box{background:var(--panel);border:1px solid var(--border);border-radius:var(--r);padding:12px;margin-top:8px}
.exit-row{display:flex;justify-content:space-between;align-items:center;padding:4px 0;border-bottom:1px solid var(--border);font-size:11px}
.exit-row:last-child{border-bottom:none}
.exit-lbl{color:var(--muted)}
.exit-val{font-family:var(--mono);font-size:12px;color:var(--text)}
.exit-val.gold{color:var(--gold);font-weight:600}

/* ── SUMMARY TAB ── */
.summary-wrap{max-width:720px;margin:0 auto}
.sum-hdr{background:var(--navy);border:1px solid var(--border);border-radius:var(--r-lg) var(--r-lg) 0 0;padding:18px 22px 14px;display:flex;align-items:flex-start;justify-content:space-between}
.sum-title{font-family:var(--serif);font-size:22px;font-weight:700;color:var(--gold);letter-spacing:.5px}
.sum-subtitle{font-size:11px;color:var(--muted);margin-top:3px;letter-spacing:.3px}
.sum-brand{text-align:right;font-size:10px;color:var(--muted);line-height:1.7}
.sum-brand strong{color:var(--gold);font-family:var(--serif);font-size:13px;font-weight:600;display:block}
.sum-info{background:var(--panel);border:1px solid var(--border);border-top:none;padding:14px 22px}
.info-grid{display:grid;grid-template-columns:auto 1fr;gap:3px 16px;font-size:12px}
.info-lbl{color:var(--muted);font-weight:600;white-space:nowrap;padding:1px 0}
.info-val{color:var(--text);padding:1px 0}
.sum-section{background:var(--panel);border:1px solid var(--border);border-top:none;padding:0}
.sum-section-hdr{background:var(--navy);padding:8px 22px;font-size:10px;font-weight:700;color:var(--gold);text-transform:uppercase;letter-spacing:1.2px;border-top:1px solid var(--border)}
.sum-dual{display:grid;grid-template-columns:1fr 1fr;border-top:none}
.sum-col{padding:0 0 8px}
.sum-col-hdr{text-align:center;padding:8px 14px 6px;font-size:11px;font-weight:700;color:var(--gold);background:rgba(201,168,76,.07);letter-spacing:.5px;border-bottom:1px solid var(--border)}
.sum-row{display:grid;grid-template-columns:1fr auto;padding:4px 14px;font-size:12px;border-bottom:1px solid rgba(27,46,72,.5)}
.sum-row:last-child{border-bottom:none}
.sum-row-lbl{color:var(--muted)}
.sum-row-val{font-family:var(--mono);font-size:12px;color:var(--text);text-align:right;min-width:90px}
.sum-row-val.gold{color:var(--gold);font-weight:600}
.sum-row-val.neg{color:var(--red)}
.sum-row-val.green{color:var(--green)}
.sum-row.key{background:rgba(201,168,76,.07)}
.sum-row.key .sum-row-lbl{color:var(--text);font-weight:600}
.sum-divider{border:none;border-top:1px solid var(--border);margin:0}
.sum-bps{display:grid;grid-template-columns:1fr 1fr 1fr;gap:0;border-top:1px solid var(--border)}
.sum-bps-tile{text-align:center;padding:12px 8px;border-right:1px solid var(--border)}
.sum-bps-tile:last-child{border-right:none}
.sum-bps-t{font-size:9px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px}
.sum-bps-v{font-family:var(--serif);font-size:22px;font-weight:700;color:var(--gold)}
.sum-kpi{display:grid;grid-template-columns:1fr 1fr 1fr;border-top:1px solid var(--border)}
.sum-kpi-tile{text-align:center;padding:10px 8px;border-right:1px solid var(--border)}
.sum-kpi-tile:last-child{border-right:none}
.sum-kpi-t{font-size:9px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;margin-bottom:4px}
.sum-kpi-v{font-size:18px;font-weight:600;color:var(--text);font-family:var(--sans)}
.sum-metrics{width:100%;border-collapse:collapse;font-size:12px}
.sum-metrics th{background:rgba(201,168,76,.08);color:var(--text-dim);font-weight:600;padding:7px 14px;border-bottom:1px solid var(--border);text-align:center;font-size:11px}
.sum-metrics th:first-child{text-align:left}
.sum-metrics td{padding:5px 14px;border-bottom:1px solid rgba(27,46,72,.5);text-align:center;color:var(--text)}
.sum-metrics td:first-child{text-align:left;color:var(--muted)}
.sum-metrics tr:last-child td{border-bottom:none}
.sum-footer{background:var(--panel);border:1px solid var(--border);border-top:none;border-radius:0 0 var(--r-lg) var(--r-lg);padding:10px 22px}
.sum-source{font-size:10px;color:var(--muted);font-style:italic;line-height:1.6}
.sum-feasible{margin:0 0 12px;padding:8px 14px;border-radius:var(--r);font-size:11px;font-weight:600;text-align:center}
.sum-feasible.ok{background:var(--green-dim);border:1px solid rgba(13,158,110,.25);color:#4dd9a0}
.sum-feasible.warn{background:var(--red-dim);border:1px solid rgba(201,76,76,.2);color:#e08080}
.print-btn{float:right;font-size:11px;padding:5px 14px;border-radius:var(--r);border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;font-family:var(--sans);transition:.15s;margin-bottom:10px}
.print-btn:hover{border-color:var(--gold);color:var(--gold);background:var(--gold-dim)}
@media print{
  *{-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important}
  html,body{height:auto;overflow:visible;background:#fff}
  .topbar,.sidebar,.tabs-bar,.print-btn,.out-panel{display:none!important}
  .app{display:block;height:auto}
  .main{display:block;height:auto;overflow:visible}
  .content{display:block;height:auto;overflow:visible}
  .tab-content{display:none!important;overflow:visible}
  #tab-5{display:block!important;padding:0;height:auto;overflow:visible}
  .summary-wrap{max-width:100%;margin:0}
  /* Light print theme */
  body,.sum-info,.sum-section,.sum-footer,.sum-col,.out-panel{background:#fff!important;color:#111!important}
  .sum-hdr{background:#0A1628!important;color:#fff!important;border-radius:0!important}
  .sum-title{color:#C9A84C!important}
  .sum-subtitle,.sum-brand{color:#ccc!important}
  .sum-brand strong{color:#C9A84C!important}
  .sum-section-hdr{background:#0A1628!important;color:#C9A84C!important}
  .sum-col-hdr{background:rgba(201,168,76,.15)!important;color:#7a5c00!important;border:1px solid #e8d5a0!important}
  .sum-row{border-bottom:1px solid #e8ecf0!important}
  .sum-row-lbl{color:#555!important}
  .sum-row-val{color:#111!important}
  .sum-row-val.gold{color:#7a5c00!important;font-weight:700!important}
  .sum-row-val.neg{color:#c00!important}
  .sum-row.key{background:#fdf8ec!important}
  .sum-row.key .sum-row-lbl{color:#111!important;font-weight:700!important}
  .sum-kpi{border-top:1px solid #ddd!important}
  .sum-kpi-tile{background:#f7f9fc!important;border:1px solid #e0e6ed!important}
  .sum-kpi-t{color:#666!important}
  .sum-kpi-v{color:#111!important}
  .sum-bps{border-top:1px solid #ddd!important}
  .sum-bps-tile{background:#f7f9fc!important;border-right:1px solid #ddd!important}
  .sum-bps-t{color:#666!important}
  .sum-bps-v{color:#7a5c00!important}
  .sum-feasible.ok{background:#e6f9f0!important;border:1px solid #4dd9a0!important;color:#0a6b42!important}
  .sum-feasible.warn{background:#fef0f0!important;border:1px solid #e08080!important;color:#8b0000!important}
  .sum-metrics th{background:#f0f4f8!important;color:#333!important}
  .sum-metrics td{color:#111!important}
  .sum-metrics td:first-child{color:#555!important}
  .sum-metrics tr:nth-child(even){background:#f8fafc!important}
  .info-grid .info-lbl{color:#444!important}
  .info-grid .info-val{color:#111!important}
  .sum-source{color:#666!important}
  .sum-footer{background:#f8fafc!important;border:1px solid #ddd!important;border-top:none!important}
  .sum-info{background:#f8fafc!important;border:1px solid #ddd!important;border-top:none!important}
  .sum-section{border:1px solid #ddd!important;border-top:none!important}
  .sum-dual{border-top:none!important}
  .sum-col:first-child{border-right:1px solid #ddd!important}
}
</style>
</head>
<body>
<div class="app">

  <!-- TOP BAR -->
  <div class="topbar">
    <div class="logo">AP-EX
      <span class="logo-sub">Pro Forma · TOP REAL ESTATE . AI</span>
    </div>
    <input class="proj-name-input" id="proj-name" placeholder="Project name..." value="Victory (Phase 1)">
    <div class="topbar-right">
      <span class="save-dot" id="save-dot"></span>
      <input type="file" id="import-input" accept=".json,.apex" style="display:none" onchange="handleImport(event)">
      <button class="btn" onclick="document.getElementById('import-input').click()" title="Import projects from .apex file">↓ Import</button>
      <button class="btn" onclick="openExportMenu()" title="Export projects to file">↑ Export</button>
      <span style="width:1px;background:var(--border);height:20px;margin:0 4px"></span>
      <button class="btn" onclick="duplicateProject()">Duplicate</button>
      <button class="btn btn-danger" onclick="deleteProject()">Delete</button>
      <button class="btn btn-gold" onclick="saveProject()">Save Project</button>
    </div>
  </div>

  <!-- Export Modal -->
  <div class="modal-backdrop" id="export-modal" onclick="if(event.target===this)closeExportMenu()">
    <div class="modal">
      <div class="modal-hdr">
        <div class="modal-title">Export Projects</div>
        <button class="modal-close" onclick="closeExportMenu()">×</button>
      </div>
      <div class="modal-body">
        <div class="export-option" onclick="exportCurrent()">
          <div class="export-icon">📄</div>
          <div>
            <div class="export-title">Current Project Only</div>
            <div class="export-sub">Export the project you're working on now</div>
          </div>
        </div>
        <div class="export-option" onclick="exportAll()">
          <div class="export-icon">📦</div>
          <div>
            <div class="export-title">All Saved Projects</div>
            <div class="export-sub" id="export-count">— projects saved</div>
          </div>
        </div>
        <div class="export-note">
          Exported as <code>.apex</code> file (JSON format). Drop the file back into Ap-Ex on any device to restore — works in standalone or once integrated into GRETA.
        </div>
      </div>
    </div>
  </div>

  <div class="main">

    <!-- SIDEBAR: Upload + Project List -->
    <div class="sidebar">
      <div class="sidebar-hdr">
        <span class="sidebar-title">Ap-Ex</span>
        <button class="btn-new" onclick="newProject()">+ New</button>
      </div>

      <!-- Upload Zone -->
      <div class="upload-zone" id="upload-zone">
        <input type="file" id="file-input" accept=".pdf,.png,.jpg,.jpeg" onchange="handleFileUpload(event)">
        <div class="upload-icon">📄</div>
        <div class="upload-label">
          <strong>Upload File</strong>
          Drop architectural plans<br>or proforma PDF/image
        </div>
      </div>
      <div class="upload-status" id="upload-status"></div>

      <!-- Project list -->
      <div class="proj-divider">
        <span>Saved Projects</span>
      </div>
      <div class="proj-list" id="proj-list">
        <div class="proj-empty">
          <div class="icon">📁</div>
          No saved projects yet.<br>Click + New to begin.
        </div>
      </div>
    </div>

    <!-- MAIN CONTENT: Input Tabs -->
    <div class="content">
      <div class="tabs-bar">
        <div class="tab active" onclick="switchTab(0,this)">Project</div>
        <div class="tab" onclick="switchTab(1,this)">Revenue</div>
        <div class="tab" onclick="switchTab(2,this)">Costs</div>
        <div class="tab" onclick="switchTab(3,this)">Financing</div>
        <div class="tab" onclick="switchTab(4,this)">Hold & Exit</div>
        <div class="tab" onclick="switchTab(5,this)">Summary</div>
      </div>

      <!-- TAB 0: PROJECT INFO -->
      <div class="tab-content" id="tab-0">
        <div class="section-hdr">Project Information</div>
        <div class="field"><label>Project Type</label><input type="text" data-key="project_type" value="Multi-Family Rental / Condo"></div>
        <div class="field"><label>Address</label><input type="text" data-key="address" value="13744 Bentley Rd, Surrey BC V3R 5C3"></div>
        <div class="field"><label>City / Municipality</label><input type="text" data-key="city" value="Surrey, BC"></div>
        <div class="field"><label>Property ID / Legal</label><input type="text" data-key="legal" value="17-0544-01 | Lot 2 Sec 14 Rge 2 Plan EPP118312"></div>
        <div class="field"><label>Architect / Client</label><input type="text" data-key="architect" value="Kasian Architecture / Maskeen"></div>
        <div class="field"><label>Zoning (Current / Proposed)</label><input type="text" data-key="zoning" value="RR-1 | CD1"></div>

        <div class="section-hdr" style="display:flex;align-items:center;justify-content:space-between">
          <span>Building Data</span>
          <div class="unit-toggle">
            <button class="unit-btn active" data-unit="sf" onclick="setUnit('sf',this)">Sq. Ft.</button>
            <button class="unit-btn" data-unit="m2" onclick="setUnit('m2',this)">Meter Sq.</button>
            <button class="unit-btn" data-unit="ac" onclick="setUnit('ac',this)">Acre</button>
          </div>
        </div>

        <div id="buildings-wrap"></div>
        <button class="add-bldg-btn" id="add-bldg-btn" onclick="addBuilding()">+ Add Property</button>

        <!-- Totals row -->
        <div class="totals-card" id="totals-card">
          <div class="totals-hdr">Project Totals</div>
          <div class="totals-row">
            <div class="totals-cell"><div class="totals-lbl">Gross Buildable</div><div class="totals-val gold" id="t-gba">—</div></div>
            <div class="totals-cell"><div class="totals-lbl">Rentable / Saleable</div><div class="totals-val gold" id="t-rentable">—</div></div>
            <div class="totals-cell"><div class="totals-lbl">Efficiency</div><div class="totals-val" id="t-eff">—</div></div>
            <div class="totals-cell"><div class="totals-lbl">Units</div><div class="totals-val" id="t-units">—</div></div>
          </div>
          <div class="totals-row" style="margin-top:8px">
            <div class="totals-cell"><div class="totals-lbl">Parking</div><div class="totals-val" id="t-parking">—</div></div>
            <div class="totals-cell"><div class="totals-lbl">Bicycles</div><div class="totals-val" id="t-bicycles">—</div></div>
            <div class="totals-cell"><div class="totals-lbl">Storage</div><div class="totals-val" id="t-storage">—</div></div>
            <div class="totals-cell"><div class="totals-lbl">Stalls Sold</div><div class="totals-val" id="t-stallsold">—</div></div>
          </div>
        </div>

        <div class="section-hdr">Quick Calculation Inputs</div>
        <div class="field" id="field-sale-psf">
          <label>$/Saleable</label>
          <div class="inp-wrap"><span class="inp-pre">$</span><input type="number" data-key="sale_psf_quick" value="900" class="has-pre" placeholder="e.g. 900" onchange="syncSalePsf(this)"></div>
        </div>
        <div class="field" id="field-rent-psf">
          <label>$/Leasable / month</label>
          <div class="inp-wrap"><span class="inp-pre">$</span><input type="number" data-key="rent_psf" value="3.75" step="0.05" class="has-pre" placeholder="e.g. 3.75"></div>
        </div>
        <div class="field">
          <label>Parking ($/stall sale)</label>
          <div class="inp-wrap"><span class="inp-pre">$</span><input type="number" data-key="park_price" value="40000" class="has-pre" placeholder="e.g. 40,000"></div>
        </div>
        <div class="field">
          <label>Bicycles ($/stall sale)</label>
          <div class="inp-wrap"><span class="inp-pre">$</span><input type="number" data-key="bike_price" value="2500" class="has-pre" placeholder="e.g. 2,500"></div>
        </div>
        <div class="field">
          <label>Storage ($/unit sale)</label>
          <div class="inp-wrap"><span class="inp-pre">$</span><input type="number" data-key="storage_price" value="8000" class="has-pre" placeholder="e.g. 8,000"></div>
        </div>
        <div class="field" id="field-cap-rate">
          <label>Cap Rate %</label>
          <div class="inp-wrap"><input type="number" data-key="cap_rate" value="0.0475" step="0.0025" class="has-suf" placeholder="e.g. 0.0475"><span class="inp-suf">%×</span></div>
        </div>

        <!-- Proforma Ready Banner -->
        <div class="ready-banner" id="ready-banner">
          <div class="ready-title">✓ Your proforma is ready</div>
          <div class="ready-sub">Gross Buildable and Saleable populated. Generate a shareable link or view the summary.</div>
          <div class="ready-actions">
            <button class="btn btn-gold" style="font-size:12px;padding:6px 16px" onclick="generateShareLink()">Generate Link</button>
            <button class="btn" style="font-size:12px;padding:6px 16px" onclick="switchTab(5,document.querySelectorAll('.tab')[5])">View Summary</button>
          </div>
          <div class="share-link-box" id="share-link-box">
            <input type="text" id="share-link-input" readonly>
            <div class="share-btns">
              <button class="share-btn" onclick="copyShareLink()">📋 Copy Link</button>
              <button class="share-btn" onclick="emailShareLink()">✉ Email</button>
              <button class="share-btn" onclick="switchTab(5,document.querySelectorAll('.tab')[5]);setTimeout(window.print,400)">⎙ Print PDF</button>
            </div>
          </div>
        </div>
      </div>

      <!-- TAB 1: REVENUE -->
      <div class="tab-content" id="tab-1" style="display:none">
        <div class="section-hdr">Sales Revenue</div>
        <div class="field"><label>Sale Price — Building A ($/saleable SF)</label><div class="inp-wrap"><span class="inp-pre">$</span><input type="number" data-key="sale_psf_A" value="900" class="has-pre"></div></div>
        <div class="field"><label>Sale Price — Building B ($/saleable SF)</label><div class="inp-wrap"><span class="inp-pre">$</span><input type="number" data-key="sale_psf_B" value="900" class="has-pre"></div></div>
        <div class="field"><label>Sale Price — Building C ($/saleable SF)</label><div class="inp-wrap"><span class="inp-pre">$</span><input type="number" data-key="sale_psf_C" value="900" class="has-pre"></div></div>
        <div class="field"><label>Parking Revenue ($/stall)</label><div class="inp-wrap"><span class="inp-pre">$</span><input type="number" data-key="park_price" value="40000" class="has-pre"></div></div>
        <div class="field"><label>Developer Profit Target</label><div class="inp-wrap"><input type="number" data-key="profit_margin" value="0.20" step="0.01" class="has-suf"><span class="inp-suf">%×</span></div></div>

        <div class="section-hdr">Rental Revenue</div>
        <div class="field"><label>Rent — Average ($/leasable SF/month)</label><div class="inp-wrap"><span class="inp-pre">$</span><input type="number" data-key="rent_psf" value="3.75" step="0.05" class="has-pre"></div></div>
        <div class="field"><label>Vacancy + Bad Debt Rate</label><div class="inp-wrap"><input type="number" data-key="vacancy" value="0.03" step="0.005" class="has-suf"><span class="inp-suf">%×</span></div></div>
        <div class="field"><label>Operating Expense ($/unit/year)</label><div class="inp-wrap"><span class="inp-pre">$</span><input type="number" data-key="opex_unit" value="7000" class="has-pre"></div></div>
        <div class="field"><label>Parking Rent ($/stall/month)</label><div class="inp-wrap"><span class="inp-pre">$</span><input type="number" data-key="park_rent" value="100" class="has-pre"></div></div>
        <div class="field"><label>Other Income ($/unit/year)</label><div class="inp-wrap"><span class="inp-pre">$</span><input type="number" data-key="other_inc" value="200" class="has-pre"></div></div>

        <div class="section-hdr">Cap Rates & Yields</div>
        <div class="field"><label>Going-in Cap Rate</label><div class="inp-wrap"><input type="number" data-key="cap_rate" value="0.0475" step="0.0025" class="has-suf"><span class="inp-suf">%×</span></div></div>
        <div class="field"><label>Exit Cap Rate (hold scenario)</label><div class="inp-wrap"><input type="number" data-key="exit_cap" value="0.05" step="0.0025" class="has-suf"><span class="inp-suf">%×</span></div></div>
        <div class="field"><label>Target Yield-on-Cost (buyer-protective)</label><div class="inp-wrap"><input type="number" data-key="target_yoc" value="0.0625" step="0.0025" class="has-suf"><span class="inp-suf">%×</span></div></div>
      </div>

      <!-- TAB 2: COSTS -->
      <div class="tab-content" id="tab-2" style="display:none">
        <div class="section-hdr">Location Preset — Auto-fills Hard Costs & City Fees</div>
        <div class="preset-row" id="preset-row">
          <button class="preset-btn active" onclick="applyPreset('Surrey',this)">Surrey</button>
          <button class="preset-btn" onclick="applyPreset('Vancouver',this)">Vancouver</button>
          <button class="preset-btn" onclick="applyPreset('Burnaby',this)">Burnaby</button>
          <button class="preset-btn" onclick="applyPreset('Coquitlam',this)">Coquitlam</button>
          <button class="preset-btn" onclick="applyPreset('Richmond',this)">Richmond</button>
          <button class="preset-btn" onclick="applyPreset('Langley',this)">Langley</button>
          <button class="preset-btn" onclick="applyPreset('Abbotsford',this)">Abbotsford</button>
        </div>

        <div class="section-hdr">Hard Costs</div>
        <div class="field"><label>Construction Cost ($/gross SF)</label><div class="inp-wrap"><span class="inp-pre">$</span><input type="number" data-key="constr_psf" value="375" class="has-pre"></div></div>
        <div class="field"><label>Parking Construction ($/stall)</label><div class="inp-wrap"><span class="inp-pre">$</span><input type="number" data-key="park_stall_cost" value="60000" class="has-pre"></div></div>
        <div class="field"><label>Site Servicing & Sitework (lump sum)</label><div class="inp-wrap"><span class="inp-pre">$</span><input type="number" data-key="sitework" value="750000" class="has-pre"></div></div>
        <div class="field"><label>Hard Cost Contingency</label><div class="inp-wrap"><input type="number" data-key="hard_cont" value="0.07" step="0.01" class="has-suf"><span class="inp-suf">%×</span></div></div>

        <div class="section-hdr">Soft Costs</div>
        <div class="field"><label>Consultants A/E/Struct/M&E (% of hard)</label><div class="inp-wrap"><input type="number" data-key="consultants" value="0.08" step="0.01" class="has-suf"><span class="inp-suf">%×</span></div></div>
        <div class="field"><label>Marketing & Sales — SALES (% of revenue)</label><div class="inp-wrap"><input type="number" data-key="marketing" value="0.05" step="0.01" class="has-suf"><span class="inp-suf">%×</span></div></div>
        <div class="field"><label>Lease-up Costs — RENTAL (% of GPI)</label><div class="inp-wrap"><input type="number" data-key="leaseup" value="0.06" step="0.01" class="has-suf"><span class="inp-suf">%×</span></div></div>
        <div class="field"><label>Legal & Miscellaneous (lump sum)</label><div class="inp-wrap"><span class="inp-pre">$</span><input type="number" data-key="legal_lump" value="350000" class="has-pre"></div></div>
        <div class="field"><label>Property Tax & Insurance (during dev)</label><div class="inp-wrap"><span class="inp-pre">$</span><input type="number" data-key="tax_dev" value="250000" class="has-pre"></div></div>
        <div class="field"><label>Soft Cost Contingency</label><div class="inp-wrap"><input type="number" data-key="soft_cont" value="0.10" step="0.01" class="has-suf"><span class="inp-suf">%×</span></div></div>

        <div class="section-hdr">City Costs (DCC / CAC / Permits)</div>
        <div class="field"><label>Development Cost Charges (DCC)</label><div class="inp-wrap"><span class="inp-pre">$</span><input type="number" data-key="dcc" value="6500000" class="has-pre"></div></div>
        <div class="field"><label>Community Amenity Contribution (CAC)</label><div class="inp-wrap"><span class="inp-pre">$</span><input type="number" data-key="cac" value="4000000" class="has-pre"></div></div>
        <div class="field"><label>Building Permits & Development Fees</label><div class="inp-wrap"><span class="inp-pre">$</span><input type="number" data-key="permits" value="1500000" class="has-pre"></div></div>
        <div class="field"><label>Land Park Purchase Contribution</label><div class="inp-wrap"><span class="inp-pre">$</span><input type="number" data-key="park_buy" value="270000" class="has-pre"></div></div>
      </div>

      <!-- TAB 3: FINANCING -->
      <div class="tab-content" id="tab-3" style="display:none">
        <div class="section-hdr">Strata Sales — Construction Loan</div>
        <div class="field"><label>Loan-to-Cost (LTC)</label><div class="inp-wrap"><input type="number" data-key="ltc_sales" value="0.65" step="0.05" class="has-suf"><span class="inp-suf">%×</span></div></div>
        <div class="field"><label>Construction Loan Interest Rate</label><div class="inp-wrap"><input type="number" data-key="rate_sales" value="0.08" step="0.005" class="has-suf"><span class="inp-suf">%×</span></div></div>
        <div class="field"><label>Construction Term (months)</label><input type="number" data-key="term_sales" value="30"></div>
        <div class="field"><label>Average Loan Balance (% of peak)</label><div class="inp-wrap"><input type="number" data-key="avg_bal_sales" value="0.55" step="0.05" class="has-suf"><span class="inp-suf">%×</span></div></div>

        <div class="section-hdr">CMHC MLI Select — Rental Hold</div>
        <div class="field"><label>Construction LTC (CMHC-insured)</label><div class="inp-wrap"><input type="number" data-key="ltc_rental" value="0.90" step="0.05" class="has-suf"><span class="inp-suf">%×</span></div></div>
        <div class="field"><label>Construction Loan Interest Rate</label><div class="inp-wrap"><input type="number" data-key="rate_rental" value="0.055" step="0.005" class="has-suf"><span class="inp-suf">%×</span></div></div>
        <div class="field"><label>Construction Term (months)</label><input type="number" data-key="term_rental" value="30"></div>
        <div class="field"><label>Average Loan Balance (% of peak)</label><div class="inp-wrap"><input type="number" data-key="avg_bal_rental" value="0.55" step="0.05" class="has-suf"><span class="inp-suf">%×</span></div></div>
