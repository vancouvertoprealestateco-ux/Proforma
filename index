function handleImport(event){
  const file=event.target.files[0];
  if(!file)return;
  const reader=new FileReader();
  reader.onload=e=>{
    try{
      const data=JSON.parse(e.target.result);
      if(!data.apex_export){showToast('⚠ Not a valid Ap-Ex export file',true);return;}
      const projects=loadIndex();
      let imported=0;
      const items=data.type==='single'?[data.project]:(data.projects||[]);
      items.forEach(p=>{
        if(!p.inputs)return;
        // Generate fresh ID to avoid collisions
        const newId='proj-'+Date.now()+'-'+Math.floor(Math.random()*1000);
        const meta={id:newId,name:p.name||p.inputs.project_name||'Imported',city:p.city||p.inputs.city||'',date:new Date().toLocaleDateString()+' (imported)'};
        projects.push(meta);
        localStorage.setItem('apex-proj-'+newId,JSON.stringify(p.inputs));
        imported++;
      });
      saveIndex(projects);
      renderProjects();
      showToast('✓ Imported '+imported+' project'+(imported===1?'':'s'));
      // Load the first imported project
      if(imported>0){
        const last=projects[projects.length-1];
        openProject(last.id);
      }
    }catch(err){
      console.error(err);
      showToast('⚠ Could not read file — invalid format',true);
    }
    event.target.value='';
  };
  reader.readAsText(file);
}

