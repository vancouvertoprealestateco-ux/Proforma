// Bug 2: Unit Toggle
let currentUnit='sf';
const UNIT_FACTORS={sf:1, m2:0.092903, ac:0.0000229568};
const UNIT_LABELS={sf:'SF', m2:'m²', ac:'Acres'};

function setUnit(unit,btn){
  const fromFactor=UNIT_FACTORS[currentUnit];
  const toFactor=UNIT_FACTORS[unit];
  document.querySelectorAll('[data-area]').forEach(el=>{
    const v=parseFloat(el.value);
    if(isFinite(v)) el.value=(v*(fromFactor/toFactor)).toFixed(unit==='ac'?4:0);
  });
