<script>
const PRESETS = {
  Surrey:      {constr_psf:375,park_stall_cost:60000,dcc:6500000,cac:4000000,permits:1500000,park_buy:270000},
  Vancouver:   {constr_psf:455,park_stall_cost:85000,dcc:9200000,cac:6500000,permits:2800000,park_buy:350000},
  Burnaby:     {constr_psf:405,park_stall_cost:72000,dcc:7800000,cac:5200000,permits:2100000,park_buy:300000},
  Coquitlam:   {constr_psf:360,park_stall_cost:55000,dcc:5800000,cac:3200000,permits:1100000,park_buy:220000},
  Richmond:    {constr_psf:395,park_stall_cost:68000,dcc:7200000,cac:4800000,permits:1900000,park_buy:280000},
  Langley:     {constr_psf:340,park_stall_cost:50000,dcc:5200000,cac:2800000,permits:950000, park_buy:180000},
  Abbotsford:  {constr_psf:320,park_stall_cost:45000,dcc:4500000,cac:2200000,permits:800000, park_buy:150000},
};

const fmt$ = v => {
  if(!isFinite(v)) return 'n/a';
  const abs=Math.abs(v), neg=v<0;
  if(abs>=1e6) return (neg?'−':'')+'$'+(abs/1e6).toFixed(1)+'M';
  if(abs>=1000) return (neg?'−':'')+'$'+Math.round(abs).toLocaleString();
  return (neg?'−':'')+'$'+abs.toFixed(2);
};
const fmtPct=(v,d=1)=>isFinite(v)?(v*100).toFixed(d)+'%':'n/a';
const fmtX=v=>isFinite(v)?v.toFixed(2)+'x':'n/a';
const fmtBPS=v=>isFinite(v)?Math.round(v)+' bps':'n/a';

function pmt(rate,nper,pv){
  if(rate===0)return pv/nper;
  return (rate*pv)/(1-Math.pow(1+rate,-nper));
}

function getInputs(){
  const i={};
  document.querySelectorAll('[data-key]').forEach(el=>{
    const v=parseFloat(el.value);
    i[el.dataset.key]=isNaN(v)?el.value:v;
  });
  i.project_name=document.getElementById('proj-name').value;
  return i;
}

function setInputs(i){
  document.querySelectorAll('[data-key]').forEach(el=>{
    const k=el.dataset.key;
    if(i[k]!==undefined) el.value=i[k];
  });
  if(i.project_name) document.getElementById('proj-name').value=i.project_name;
}

function calculate(i){
  // Sum across all possible buildings (A-H) — empty/undefined = 0
  const BL = ['A','B','C','D','E','F','G','H'];
  const sumN = key => BL.reduce((s,l) => s + (parseFloat(i[key + '_' + l]) || 0), 0);
  const gba = sumN('gba');
  const rent = sumN('rentable');
  const units = sumN('units');
  const totalParking = sumN('parking');
  const totalBicycles = sumN('bicycles');
  const totalStorage = sumN('storage');

  // Override park_stalls with calculated total
  const park_stalls = totalParking;
  const park_sold = parseFloat(i.park_sold) || totalParking;
  const bike_price = parseFloat(i.bike_price) || 0;
  const storage_price = parseFloat(i.storage_price) || 0;

  // SALES — revenue includes per-building saleable × $/SF, plus parking/bicycles/storage
  const psf_quick = parseFloat(i.sale_psf_quick) || 0;
  const revBldg = BL.reduce((s,l) => {
    const r = parseFloat(i['rentable_' + l]) || 0;
    const psf = parseFloat(i['sale_psf_' + l]) || psf_quick;
    return s + r * psf;
  }, 0);
  const revenue = revBldg + park_sold * (i.park_price || 0) + totalBicycles * bike_price + totalStorage * storage_price;

  const hard_sub = gba * i.constr_psf + park_stalls * i.park_stall_cost + i.sitework;
  const hard_s = hard_sub * (1 + i.hard_cont);
  const soft_sub_s = hard_s * i.consultants + revenue * i.marketing + i.legal_lump + i.tax_dev;
  const soft_s = soft_sub_s * (1 + i.soft_cont);
  const city = i.dcc + i.cac + i.permits + i.park_buy;
  const peak_s = (hard_s + soft_s + city) * i.ltc_sales;
  const fin_s = peak_s * i.avg_bal_sales * i.rate_sales * i.term_sales / 12;
  const profit = revenue * i.profit_margin;
  const csub_s = hard_s + soft_s + city + fin_s;
  const rlv = revenue - csub_s - profit;
  const tpc_s = csub_s + rlv;
  const roc_s = tpc_s > 0 ? profit / tpc_s : 0;
  const eq_s = tpc_s * (1 - i.ltc_sales);
  const em_s = eq_s > 0 ? (eq_s + profit) / eq_s : 0;
  const irr_s = eq_s > 0 ? Math.pow(1 + (profit / eq_s), 12 / i.term_sales) - 1 : 0;

  // RENTAL
  const gpi = rent * i.rent_psf * 12 + park_stalls * i.park_rent * 12 + units * i.other_inc;
  const egi = gpi * (1 - i.vacancy);
  const noi = egi - units * i.opex_unit;
  const mv = i.cap_rate > 0 ? noi / i.cap_rate : 0;
  const hard_r = hard_sub * (1 + i.hard_cont);
  const soft_sub_r = hard_r * i.consultants + gpi * i.leaseup + i.legal_lump + i.tax_dev;
  const soft_r = soft_sub_r * (1 + i.soft_cont);
  const peak_r = (hard_r + soft_r + city) * i.ltc_rental;
  const fin_r = peak_r * i.avg_bal_rental * i.rate_rental * i.term_rental / 12;
  const csub_r = hard_r + soft_r + city + fin_r;
  const mc = pmt(i.cmhc_rate / 12, i.cmhc_amort * 12, 1) * 12;
  const max_ltv = mv * i.cmhc_ltv;
  const max_dscr_l = mc > 0 ? noi / i.min_dscr / mc : 0;
  const tn = Math.min(max_ltv, max_dscr_l);
  const tg = tn * (1 + i.cmhc_prem);
  const ads = tg * mc;
  const dscr = ads > 0 ? noi / ads : 0;
  const land = i.target_yoc > 0 ? noi / i.target_yoc - csub_r : 0;
  const tpc_r = csub_r + land;
  const yoc = tpc_r > 0 ? noi / tpc_r : 0;
  const bps = (i.target_yoc - i.cap_rate) * 10000;
  const cf1 = noi - ads;
  const eq_r = tpc_r * (1 - i.ltc_rental);
  const refi = tg - peak_r;
  const eq_post = eq_r - refi;
  const coc = eq_post > 0 ? cf1 / eq_post : 0;

  // EXIT
  const exit_noi = noi * Math.pow(1 + i.noi_growth, i.hold_yrs);
  const exit_gross = i.exit_cap > 0 ? exit_noi / i.exit_cap : 0;
  const exit_cost = exit_gross * i.sell_cost;
  const rem_loan=tg*0.88;
  const exit_net=exit_gross-exit_cost-rem_loan;
  const sens_25=exit_noi/(i.exit_cap+0.0025)-exit_gross;
  const exit_alt=exit_noi*Math.pow(1+(i.noi_growth+0.025),i.hold_yrs-i.hold_yrs)/i.exit_cap;

  return {revenue,hard_s,soft_s,city,fin_s,profit,rlv,roc_s,eq_s,em_s,irr_s,
    noi,mv,hard_r,soft_r,fin_r,tg,dscr,land,yoc,bps,cf1,eq_post,coc,
    exit_noi,exit_gross,exit_cost,rem_loan,exit_net,sens_25,tpc_s,tpc_r};
}

