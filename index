let activeBuildings = ['A'];  // letters of currently visible buildings
const ALL_LETTERS = ['A','B','C','D','E','F','G','H'];

function renderBuildings(){
  const wrap = document.getElementById('buildings-wrap');
  if(!wrap) return;
  const unit = UNIT_LABELS[currentUnit] || 'SF';
  wrap.innerHTML = activeBuildings.map((letter, idx) => `
    <div class="bldg-card" data-letter="${letter}">
      <div class="bldg-card-hdr">
        <div class="bldg-card-title">Building ${letter}</div>
        ${idx === 0 ? '' : `<button class="bldg-remove" onclick="removeBuilding('${letter}')" title="Remove building">×</button>`}
      </div>
      <div class="bldg-grid">
        <div>
          <div class="field"><label>Gross Buildable</label><input type="number" data-key="gba_${letter}" data-area="1" data-bldg-input="1"></div>
          <div class="field"><label>Rentable / Saleable</label><input type="number" data-key="rentable_${letter}" data-area="1" data-bldg-input="1"></div>
          <div class="field calc-field"><label>Efficiency</label><input type="text" data-key="eff_${letter}" readonly placeholder="—"></div>
          <div class="field"><label>Units</label><input type="number" data-key="units_${letter}" data-bldg-input="1"></div>
        </div>
        <div>
          <div class="field"><label>Parking (stalls)</label><input type="number" data-key="parking_${letter}" data-bldg-input="1"></div>
          <div class="field"><label>Bicycles (stalls)</label><input type="number" data-key="bicycles_${letter}" data-bldg-input="1"></div>
          <div class="field"><label>Storage (units)</label><input type="number" data-key="storage_${letter}" data-bldg-input="1"></div>
        </div>
      </div>
    </div>
  `).join('');

  // Attach input listeners
  wrap.querySelectorAll('input').forEach(el => {
    el.addEventListener('input', () => {
      updateBuildingEfficiency(el.dataset.key);
      updateOutput();
      updateTotals();
      checkReady();
    });
  });

  updateAddButton();
  updateTotals();
}

function updateAddButton(){
  const btn = document.getElementById('add-bldg-btn');
  if(!btn) return;
  if(activeBuildings.length >= ALL_LETTERS.length){
    btn.disabled = true;
    btn.textContent = 'Maximum buildings reached';
  } else {
    btn.disabled = false;
    const nextLetter = ALL_LETTERS[activeBuildings.length];
    btn.textContent = '+ Add Property (Building ' + nextLetter + ')';
  }
}

function addBuilding(){
  if(activeBuildings.length >= ALL_LETTERS.length) return;
  const nextLetter = ALL_LETTERS[activeBuildings.length];
  activeBuildings.push(nextLetter);
  renderBuildings();
  updateOutput();
}

function removeBuilding(letter){
  if(activeBuildings.length <= 1) return;
  if(!confirm('Remove Building ' + letter + '? Any data entered will be lost.')) return;
  // Clear values for this building
  ['gba','rentable','units','parking','bicycles','storage','eff'].forEach(prefix => {
    delete window._inputCache?.[prefix + '_' + letter];
  });
  activeBuildings = activeBuildings.filter(l => l !== letter);
  renderBuildings();
  updateOutput();
  updateTotals();
  checkReady();
}

function updateBuildingEfficiency(key){
  if(!key) return;
  const m = key.match(/^(gba|rentable)_([A-H])$/);
  if(!m) return;
  const letter = m[2];
  const gba = parseFloat(document.querySelector(`[data-key="gba_${letter}"]`)?.value || 0);
  const rent = parseFloat(document.querySelector(`[data-key="rentable_${letter}"]`)?.value || 0);
  const eff = (gba > 0) ? (rent / gba * 100).toFixed(1) + '%' : '';
  const effEl = document.querySelector(`[data-key="eff_${letter}"]`);
  if(effEl) effEl.value = eff;
}

function updateTotals(){
  const sum = key_prefix => activeBuildings.reduce((s, l) => {
    return s + (parseFloat(document.querySelector(`[data-key="${key_prefix}_${l}"]`)?.value) || 0);
  }, 0);
  const totalGba = sum('gba');
  const totalRent = sum('rentable');
  const totalUnits = sum('units');
  const totalPark = sum('parking');
  const totalBike = sum('bicycles');
  const totalStorage = sum('storage');
  const eff = totalGba > 0 ? (totalRent / totalGba * 100).toFixed(1) + '%' : '—';
  const fmt = v => v > 0 ? Math.round(v).toLocaleString() : '—';
  const set = (id, v) => { const el = document.getElementById(id); if(el) el.textContent = v; };
  set('t-gba', fmt(totalGba));
  set('t-rentable', fmt(totalRent));
  set('t-eff', eff);
  set('t-units', fmt(totalUnits));
  set('t-parking', fmt(totalPark));
  set('t-bicycles', fmt(totalBike));
  set('t-storage', fmt(totalStorage));
  // Also update legacy park_stalls (used by calculate())
  const stallsInput = document.querySelector('[data-key="park_stalls"]');
  if(stallsInput) stallsInput.value = totalPark || 0;
  const soldInput = document.querySelector('[data-key="park_sold"]');
  if(soldInput && (!soldInput.dataset.userSet)) soldInput.value = totalPark || 0;
  set('t-stallsold', fmt(parseFloat(soldInput?.value) || 0));
}

// Set building values (used when loading project or extracting from PDF)
function setBuildingValues(inputs){
  // Detect which buildings have data
  activeBuildings = [];
  ALL_LETTERS.forEach(l => {
    if((inputs['gba_'+l] && inputs['gba_'+l] > 0) ||
       (inputs['rentable_'+l] && inputs['rentable_'+l] > 0) ||
       (inputs['units_'+l] && inputs['units_'+l] > 0)){
      activeBuildings.push(l);
    }
  });
  if(activeBuildings.length === 0) activeBuildings = ['A'];
  renderBuildings();
  // Now populate the inputs
  ALL_LETTERS.forEach(l => {
    ['gba','rentable','units','parking','bicycles','storage'].forEach(p => {
      const k = p + '_' + l;
      if(inputs[k] !== undefined){
        const el = document.querySelector(`[data-key="${k}"]`);
        if(el) el.value = inputs[k];
      }
    });
    updateBuildingEfficiency('gba_' + l);
  });
  updateTotals();
}

